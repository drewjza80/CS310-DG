#include <iostream>
using namespace std;

int main() {
    int score;

    cout << "Enter your test score (0-100): ";
    cin >> score;

    // Determine the letter grade using selection statements
    if score >= 90 {
        letterGrade = 'A';
    } else if (score >= 80) {
        letterGrade = 'B';
    } else if (score >= 70) {
        letterGrade = 'C';
    } else {
        letterGrade = 'F';
    }

    // Output the final result
    cout << "Your letter grade is: " << letterGrade << endl;

    return 0;
}
